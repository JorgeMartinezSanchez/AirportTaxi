pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    environment {
        PROJECT_PATH = '/app/asphanorisbeta'
        MAVEN_HOME = '/usr/share/maven'
        JAVA_HOME = '/usr/lib/jvm/java-17-openjdk-amd64'
    }

    stages {
        stage('Checkout') {
            steps {
                echo '📦 Clonando repositorio...'
                checkout scm
                echo '✅ Checkout completado'
            }
        }

        stage('Compile') {
            steps {
                echo '🔨 Compilando proyecto...'
                dir('/app/asphanorisbeta') {
                    sh 'mvn clean compile'
                }
                echo '✅ Compilación exitosa'
            }
        }

        stage('Run Tests') {
            steps {
                echo '🧪 Ejecutando pruebas...'
                dir('/app/asphanorisbeta') {
                    sh 'mvn test'
                }
                echo '✅ Pruebas completadas'
            }
            post {
                always {
                    junit '/app/asphanorisbeta/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Package') {
            steps {
                echo '📦 Empaquetando aplicación...'
                dir('/app/asphanorisbeta') {
                    sh 'mvn package -DskipTests'
                }
                echo '✅ JAR creado exitosamente'
            }
            post {
                success {
                    archiveArtifacts artifacts: '/app/asphanorisbeta/target/*.jar'
                }
            }
        }

        stage('Deploy') {
            steps {
                echo '🚀 Desplegando aplicación...'
                sh '''
                    cd /app/asphanorisbeta
                    docker stop asphanoris-app 2>/dev/null || true
                    docker rm asphanoris-app 2>/dev/null || true
                    docker run -d \
                        --name asphanoris-app \
                        -p 8081:8081 \
                        -v /app/asphanorisbeta/target:/app \
                        openjdk:17-jre-slim \
                        java -jar /app/*.jar
                '''
                echo '✅ Despliegue completado'
            }
        }
    }

    post {
        success {
            echo '🎉 Pipeline completado exitosamente!'
        }
        failure {
            echo '❌ Pipeline falló!'
        }
    }
}